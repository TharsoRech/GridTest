<?xml version="1.0" encoding="UTF-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="GridTest.Components.HeaderView">

    <Grid Padding="0,0,0,16"
          ColumnDefinitions="*,Auto">

        <!-- Left: Page Title -->
        <VerticalStackLayout Grid.Column="0"
                             VerticalOptions="Center"
                             Spacing="4">
            <Label Text="Dashboard"
                   FontSize="24"
                   FontFamily="OpenSansSemibold"
                   TextColor="{StaticResource TextPrimary}" />
            <Label Text="Welcome back! Here's your overview."
                   FontSize="13"
                   TextColor="{StaticResource TextSecondary}" />
        </VerticalStackLayout>

        <!-- Right: Controls -->
        <HorizontalStackLayout Grid.Column="1"
                               Spacing="12"
                               VerticalOptions="Center">

            <!-- Search Bar -->
            <Border BackgroundColor="#F0F3F8"
                    StrokeShape="RoundRectangle 8"
                    StrokeThickness="0"
                    Padding="12,8"
                    HeightRequest="40">
                <HorizontalStackLayout Spacing="8">
                    <Label Text="🔍" FontSize="14" VerticalTextAlignment="Center" />
                    <Label Text="Search..." FontSize="13"
                           TextColor="{StaticResource TextTertiary}"
                           VerticalTextAlignment="Center" />
                </HorizontalStackLayout>
            </Border>

            <!-- Notification Bell -->
            <Border BackgroundColor="#F0F3F8"
                    StrokeShape="RoundRectangle 8"
                    StrokeThickness="0"
                    WidthRequest="40" HeightRequest="40"
                    Padding="0">
                <Grid>
                    <Label Text="🔔" FontSize="18"
                           HorizontalTextAlignment="Center"
                           VerticalTextAlignment="Center" />
                    <!-- Badge -->
                    <Border WidthRequest="16" HeightRequest="16"
                            BackgroundColor="{StaticResource AccentOrange}"
                            StrokeShape="RoundRectangle 8"
                            StrokeThickness="0"
                            HorizontalOptions="End"
                            VerticalOptions="Start"
                            Margin="0,-2,-2,0"
                            Padding="0">
                        <Label Text="3" FontSize="9" TextColor="White"
                               HorizontalTextAlignment="Center"
                               VerticalTextAlignment="Center" />
                    </Border>
                </Grid>
            </Border>

            <!-- User Avatar -->
            <Border WidthRequest="40" HeightRequest="40"
                    StrokeShape="RoundRectangle 20"
                    StrokeThickness="0"
                    BackgroundColor="{StaticResource ChartBlue}"
                    Padding="0">
                <Label Text="A" FontSize="16" TextColor="White"
                       FontFamily="OpenSansSemibold"
                       HorizontalTextAlignment="Center"
                       VerticalTextAlignment="Center" />
            </Border>
        </HorizontalStackLayout>
    </Grid>
</ContentView>
