<?xml version="1.0" encoding="UTF-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="GridTest.Components.SidebarView">

    <Grid BackgroundColor="{StaticResource SidebarDarkBlue}"
          WidthRequest="220"
          HorizontalOptions="Start">
        <Grid.RowDefinitions>
            <RowDefinition Height="70" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Logo / Brand Area -->
        <VerticalStackLayout Grid.Row="0"
                             VerticalOptions="Center"
                             Padding="20,0"
                             Spacing="4">
            <Label Text="Grid"
                   FontSize="22"
                   FontFamily="OpenSansSemibold"
                   TextColor="White" />
            <Label Text="Dashboard"
                   FontSize="11"
                   TextColor="{StaticResource SidebarInactiveItem}" />
        </VerticalStackLayout>

        <!-- Menu Items -->
        <ScrollView Grid.Row="1"
                    VerticalScrollBarVisibility="Never">
            <VerticalStackLayout x:Name="MenuItemsContainer"
                                 Spacing="2"
                                 Padding="0,10">
                <!-- Dashboard (Active) -->
                <HorizontalStackLayout Spacing="12" Padding="16,12"
                                       BackgroundColor="#1AFFFFFF">
                    <Label Text="⊞" FontSize="18" TextColor="White"
                           VerticalTextAlignment="Center" WidthRequest="24" />
                    <Label Text="Dashboard" FontSize="14"
                           FontFamily="OpenSansSemibold" TextColor="White"
                           VerticalTextAlignment="Center" />
                </HorizontalStackLayout>

                <!-- Widgets -->
                <HorizontalStackLayout Spacing="12" Padding="16,12">
                    <Label Text="◈" FontSize="18"
                           TextColor="{StaticResource SidebarInactiveItem}"
                           VerticalTextAlignment="Center" WidthRequest="24" />
                    <Label Text="Widgets" FontSize="14"
                           TextColor="{StaticResource SidebarInactiveItem}"
                           VerticalTextAlignment="Center" />
                </HorizontalStackLayout>

                <!-- UI Elements -->
                <HorizontalStackLayout Spacing="12" Padding="16,12">
                    <Label Text="◉" FontSize="18"
                           TextColor="{StaticResource SidebarInactiveItem}"
                           VerticalTextAlignment="Center" WidthRequest="24" />
                    <Label Text="UI Elements" FontSize="14"
                           TextColor="{StaticResource SidebarInactiveItem}"
                           VerticalTextAlignment="Center" />
                </HorizontalStackLayout>

                <!-- Advanced UI -->
                <HorizontalStackLayout Spacing="12" Padding="16,12">
                    <Label Text="⚙" FontSize="18"
                           TextColor="{StaticResource SidebarInactiveItem}"
                           VerticalTextAlignment="Center" WidthRequest="24" />
                    <Label Text="Advanced UI" FontSize="14"
                           TextColor="{StaticResource SidebarInactiveItem}"
                           VerticalTextAlignment="Center" />
                </HorizontalStackLayout>

                <!-- Charts -->
                <HorizontalStackLayout Spacing="12" Padding="16,12">
                    <Label Text="◐" FontSize="18"
                           TextColor="{StaticResource SidebarInactiveItem}"
                           VerticalTextAlignment="Center" WidthRequest="24" />
                    <Label Text="Charts" FontSize="14"
                           TextColor="{StaticResource SidebarInactiveItem}"
                           VerticalTextAlignment="Center" />
                </HorizontalStackLayout>

                <!-- Tables -->
                <HorizontalStackLayout Spacing="12" Padding="16,12">
                    <Label Text="▦" FontSize="18"
                           TextColor="{StaticResource SidebarInactiveItem}"
                           VerticalTextAlignment="Center" WidthRequest="24" />
                    <Label Text="Tables" FontSize="14"
                           TextColor="{StaticResource SidebarInactiveItem}"
                           VerticalTextAlignment="Center" />
                </HorizontalStackLayout>

                <!-- Popups -->
                <HorizontalStackLayout Spacing="12" Padding="16,12">
                    <Label Text="◻" FontSize="18"
                           TextColor="{StaticResource SidebarInactiveItem}"
                           VerticalTextAlignment="Center" WidthRequest="24" />
                    <Label Text="Popups" FontSize="14"
                           TextColor="{StaticResource SidebarInactiveItem}"
                           VerticalTextAlignment="Center" />
                </HorizontalStackLayout>

                <!-- Notifications -->
                <HorizontalStackLayout Spacing="12" Padding="16,12">
                    <Label Text="◬" FontSize="18"
                           TextColor="{StaticResource SidebarInactiveItem}"
                           VerticalTextAlignment="Center" WidthRequest="24" />
                    <Label Text="Notifications" FontSize="14"
                           TextColor="{StaticResource SidebarInactiveItem}"
                           VerticalTextAlignment="Center" />
                </HorizontalStackLayout>

                <!-- Icons -->
                <HorizontalStackLayout Spacing="12" Padding="16,12">
                    <Label Text="★" FontSize="18"
                           TextColor="{StaticResource SidebarInactiveItem}"
                           VerticalTextAlignment="Center" WidthRequest="24" />
                    <Label Text="Icons" FontSize="14"
                           TextColor="{StaticResource SidebarInactiveItem}"
                           VerticalTextAlignment="Center" />
                </HorizontalStackLayout>

                <!-- Maps -->
                <HorizontalStackLayout Spacing="12" Padding="16,12">
                    <Label Text="◎" FontSize="18"
                           TextColor="{StaticResource SidebarInactiveItem}"
                           VerticalTextAlignment="Center" WidthRequest="24" />
                    <Label Text="Maps" FontSize="14"
                           TextColor="{StaticResource SidebarInactiveItem}"
                           VerticalTextAlignment="Center" />
                </HorizontalStackLayout>

                <!-- Forms -->
                <HorizontalStackLayout Spacing="12" Padding="16,12">
                    <Label Text="▤" FontSize="18"
                           TextColor="{StaticResource SidebarInactiveItem}"
                           VerticalTextAlignment="Center" WidthRequest="24" />
                    <Label Text="Forms" FontSize="14"
                           TextColor="{StaticResource SidebarInactiveItem}"
                           VerticalTextAlignment="Center" />
                </HorizontalStackLayout>

                <!-- Calendar -->
                <HorizontalStackLayout Spacing="12" Padding="16,12">
                    <Label Text="▣" FontSize="18"
                           TextColor="{StaticResource SidebarInactiveItem}"
                           VerticalTextAlignment="Center" WidthRequest="24" />
                    <Label Text="Calendar" FontSize="14"
                           TextColor="{StaticResource SidebarInactiveItem}"
                           VerticalTextAlignment="Center" />
                </HorizontalStackLayout>
            </VerticalStackLayout>
        </ScrollView>

        <!-- Bottom User Profile -->
        <Border Grid.Row="2"
                BackgroundColor="#1AFFFFFF"
                StrokeShape="RoundRectangle 0"
                StrokeThickness="0"
                Padding="16,14">
            <HorizontalStackLayout Spacing="10">
                <Border WidthRequest="34" HeightRequest="34"
                        StrokeShape="RoundRectangle 17"
                        StrokeThickness="0"
                        BackgroundColor="{StaticResource AccentOrange}">
                    <Label Text="U" TextColor="White" FontSize="14"
                           FontFamily="OpenSansSemibold"
                           HorizontalTextAlignment="Center"
                           VerticalTextAlignment="Center" />
                </Border>
                <VerticalStackLayout VerticalOptions="Center" Spacing="2">
                    <Label Text="User Name" FontSize="13"
                           FontFamily="OpenSansSemibold" TextColor="White" />
                    <Label Text="Admin" FontSize="11"
                           TextColor="{StaticResource SidebarInactiveItem}" />
                </VerticalStackLayout>
            </HorizontalStackLayout>
        </Border>
    </Grid>
</ContentView>
