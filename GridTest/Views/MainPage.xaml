<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:components="clr-namespace:GridTest.Components"
             xmlns:entities="clr-namespace:GridTest.Domain.Entities;assembly=GridTest.Domain"
             xmlns:converters="clr-namespace:GridTest.Converters"
             xmlns:vm="clr-namespace:GridTest.ViewModels;assembly=GridTest.ViewModels"
             x:Class="GridTest.Views.MainPage"
             x:DataType="vm:MainPageViewModel">
    
    <ScrollView BackgroundColor="{StaticResource BackgroundGray}">
        <VerticalStackLayout Spacing="16" Padding="16">
            <!-- Header -->
            <components:HeaderView />
            
            <!-- Earnings Panel -->
            <components:EarningsPanelView BindingContext="{Binding Metrics}"
                                          Margin="0,12,0,0" />
            
            <!-- Traffic Distribution -->
            <components:TrafficChartView BindingContext="{Binding Metrics}" />
            
            <!-- Card Metrics (FlexLayout wrapping 2 per row) -->
            <FlexLayout Wrap="Wrap" JustifyContent="SpaceBetween" Margin="0,4,0,0"
                        BindableLayout.ItemsSource="{Binding Metrics.CardMetrics}">
                <BindableLayout.ItemTemplate>
                    <DataTemplate x:DataType="entities:CardMetric">
                        <components:CardView Title="{Binding Title}" 
                                             Trend="{Binding Trend}"
                                             SubText="{Binding SubText}"
                                             ChartType="{Binding ChartType}"
                                             PathData="{Binding PathData}"
                                             PickerOptions="{Binding PickerOptions}"
                                             SelectedOptionIndex="{Binding SelectedOptionIndex}"
                                             AccentColor="{Binding AccentColor, Converter={StaticResource StringToColor}}" 
                                             BackgroundColor="{Binding BackgroundColor, Converter={StaticResource StringToColor}}"
                                             FlexLayout.Basis="48%"
                                             Margin="0,0,0,12" />
                    </DataTemplate>
                </BindableLayout.ItemTemplate>
            </FlexLayout>
            
            <!-- Recent Activities -->
            <components:ActivitiesPanelView BindingContext="{Binding Metrics}" />
            
            <!-- Order Status -->
            <components:OrderStatusView BindingContext="{Binding Metrics}" />
        </VerticalStackLayout>
    </ScrollView>
    
</ContentPage>
