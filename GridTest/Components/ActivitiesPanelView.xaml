<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:entities="clr-namespace:GridTest.Domain.Entities;assembly=GridTest.Domain"
             xmlns:local="clr-namespace:GridTest.Components"
             x:Class="GridTest.Components.ActivitiesPanelView">
    
    <Border BackgroundColor="White"
            Padding="20"
            StrokeThickness="0">
        <Border.StrokeShape>
            <RoundRectangle CornerRadius="8" />
        </Border.StrokeShape>
        <Border.Shadow>
            <Shadow Brush="#1A000000" Offset="0,2" Radius="8" Opacity="0.15" />
        </Border.Shadow>
        
        <Grid RowDefinitions="Auto,Auto">
            <Label Text="Recent Activities"
                   Style="{StaticResource HeadlineLabel}"
                   FontSize="16" />
            
            <VerticalStackLayout Grid.Row="1"
                                 BindableLayout.ItemsSource="{Binding RecentActivities}"
                                 Margin="0,12,0,0">
                <BindableLayout.ItemTemplate>
                    <DataTemplate x:DataType="entities:ActivityItem">
                        <local:ListItemView />
                    </DataTemplate>
                </BindableLayout.ItemTemplate>
            </VerticalStackLayout>
        </Grid>
    </Border>
    
</ContentView>
