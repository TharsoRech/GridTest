<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="GridTest.Components.HeaderView">
    
    <Grid ColumnDefinitions="*,Auto" Padding="24,16" BackgroundColor="{StaticResource BackgroundGray}">
        <!-- Page Title -->
        <Label Text="Dashboard"
               Style="{StaticResource HeadlineLabel}"
               VerticalOptions="Center" />
        
        <!-- Right Side Actions -->
        <HorizontalStackLayout Grid.Column="1" Spacing="16" VerticalOptions="Center">
            <Border BackgroundColor="White"
                    Padding="12,8"
                    StrokeThickness="0">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="8" />
                </Border.StrokeShape>
                <Border.Shadow>
                    <Shadow Brush="#1A000000" Offset="0,2" Radius="4" Opacity="0.1" />
                </Border.Shadow>
                <Label Text="🔔" FontSize="18" />
            </Border>
            
            <Border BackgroundColor="White"
                    Padding="12,8"
                    StrokeThickness="0">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="8" />
                </Border.StrokeShape>
                <Border.Shadow>
                    <Shadow Brush="#1A000000" Offset="0,2" Radius="4" Opacity="0.1" />
                </Border.Shadow>
                <Label Text="👤" FontSize="18" />
            </Border>
        </HorizontalStackLayout>
    </Grid>
    
</ContentView>
