<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:sys="clr-namespace:System;assembly=netstandard"
             x:Class="GridTest.Components.CardView"
             x:Name="this">
    
    <Border BindingContext="{x:Reference this}"
            BackgroundColor="{Binding BackgroundColor}"
            Padding="16"
            StrokeThickness="0"
            MinimumHeightRequest="140">
        <Border.StrokeShape>
            <RoundRectangle CornerRadius="8" />
        </Border.StrokeShape>
        <Border.Shadow>
            <Shadow Brush="#1A000000" Offset="0,2" Radius="8" Opacity="0.15" />
        </Border.Shadow>
        
        <Grid RowDefinitions="Auto,Auto,*">
            <!-- Title (left) + SubText/Picker (right) -->
            <Grid ColumnDefinitions="*,Auto">
                <Label Text="{Binding Title}"
                       Style="{StaticResource CardTitleStyle}"
                       FontSize="12"
                       VerticalOptions="Center" />
                <HorizontalStackLayout Grid.Column="1" Spacing="6" VerticalOptions="Center">
                    <Label x:Name="SubTextLabel" Text="{Binding SubText}" FontSize="10" TextColor="{Binding AccentColor}"
                           VerticalOptions="Center" />
                    <Picker x:Name="SplinePicker"
                            ItemsSource="{Binding PickerOptions}"
                            SelectedIndex="{Binding SelectedOptionIndex}"
                            FontSize="9"
                            TextColor="{Binding AccentColor}"
                            BackgroundColor="Transparent"
                            HorizontalOptions="End"
                            VerticalOptions="Center"
                            HeightRequest="20"
                            WidthRequest="65"
                            IsVisible="False" />
                </HorizontalStackLayout>
            </Grid>
            
            <!-- Trend value (below title) -->
            <Label Text="{Binding Trend}"
                   Grid.Row="1"
                   FontSize="20"
                   FontAttributes="Bold"
                   TextColor="{Binding AccentColor}"
                   Margin="0,6,0,0" />
            
            <!-- ===== DECORATIVE CHART LINES (visual only) ===== -->
            <Grid Grid.Row="2" Margin="0,8,0,0" x:Name="DecorativeChartArea">
                <!-- Line 1: main wave -->
                <Path Data="M 0,28 Q 15,10 30,22 T 60,14 T 90,20 T 120,8"
                      Stroke="{Binding AccentColor}" StrokeThickness="1.5"
                      Aspect="Fill" VerticalOptions="Fill" HorizontalOptions="Fill" Opacity="0.5" />
                <!-- Line 2: secondary wave -->
                <Path Data="M 0,32 Q 20,18 40,26 T 80,16 T 120,22"
                      Stroke="{Binding AccentColor}" StrokeThickness="1"
                      Aspect="Fill" VerticalOptions="Fill" HorizontalOptions="Fill" Opacity="0.3" />
                <!-- Line 3: subtle background wave -->
                <Path Data="M 0,24 C 20,8 40,30 60,18 S 100,28 120,12"
                      Stroke="{Binding AccentColor}" StrokeThickness="0.8"
                      Aspect="Fill" VerticalOptions="Fill" HorizontalOptions="Fill" Opacity="0.2" />
            </Grid>
        </Grid>
        
        <!-- Triggers -->
        <Border.Triggers>
            <DataTrigger TargetType="Border" Binding="{Binding ChartType, Source={x:Reference this}}" Value="spline">
                <Setter TargetName="SplinePicker" Property="IsVisible" Value="True" />
                <Setter TargetName="SubTextLabel" Property="IsVisible" Value="False" />
            </DataTrigger>
            <DataTrigger TargetType="Border" Binding="{Binding ChartType, Source={x:Reference this}}" Value="none">
                <Setter TargetName="DecorativeChartArea" Property="IsVisible" Value="False" />
            </DataTrigger>
        </Border.Triggers>
    </Border>
    
</ContentView>
