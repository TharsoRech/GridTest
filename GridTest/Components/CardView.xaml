<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="GridTest.Components.CardView"
             x:Name="this">
    
    <Border BindingContext="{x:Reference this}"
            BackgroundColor="{Binding BackgroundColor}"
            Padding="16"
            StrokeThickness="0"
            MinimumHeightRequest="140">
        <Border.StrokeShape>
            <RoundRectangle CornerRadius="8" />
        </Border.StrokeShape>
        <Border.Shadow>
            <Shadow Brush="#1A000000" Offset="0,2" Radius="8" Opacity="0.15" />
        </Border.Shadow>
        
        <Grid RowDefinitions="Auto,Auto,Auto,*">
            <!-- Title -->
            <Label Text="{Binding Title}"
                   Style="{StaticResource CardTitleStyle}"
                   FontSize="12" />
            
            <!-- Value -->
            <Label Text="{Binding Value}"
                   Style="{StaticResource CardValueStyle}"
                   Grid.Row="1"
                   FontSize="22"
                   Margin="0,6,0,0" />
            
            <!-- Trend Indicator -->
            <HorizontalStackLayout Grid.Row="2" Spacing="4" Margin="0,4,0,0">
                <Label Text="▲"
                       FontSize="10"
                       TextColor="{Binding AccentColor}"
                       VerticalOptions="Center" />
                <Label Text="{Binding Trend}"
                       FontSize="12"
                       FontAttributes="Bold"
                       TextColor="{Binding AccentColor}"
                       VerticalOptions="Center" />
            </HorizontalStackLayout>
            
            <!-- Mini Sparkline Wave Chart -->
            <Path Grid.Row="3"
                  Data="M 0,25 Q 15,10 30,20 T 60,15 T 90,10 T 120,18"
                  Stroke="{Binding AccentColor}"
                  StrokeThickness="2"
                  Aspect="Fill"
                  Margin="0,8,0,0"
                  VerticalOptions="End"
                  HorizontalOptions="Fill"
                  Opacity="0.6" />
        </Grid>
    </Border>
    
</ContentView>
