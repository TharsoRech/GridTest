<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:sys="clr-namespace:System;assembly=netstandard"
             x:Class="GridTest.Components.CardView"
             x:Name="this">
    
    <Border BindingContext="{x:Reference this}"
            BackgroundColor="{Binding BackgroundColor}"
            Padding="16"
            StrokeThickness="0"
            MinimumHeightRequest="140">
        <Border.StrokeShape>
            <RoundRectangle CornerRadius="8" />
        </Border.StrokeShape>
        <Border.Shadow>
            <Shadow Brush="#1A000000" Offset="0,2" Radius="8" Opacity="0.15" />
        </Border.Shadow>
        
        <Grid RowDefinitions="Auto,Auto,*">
            <!-- Title (left) + Picker (right, only for spline) -->
            <Grid ColumnDefinitions="*,Auto">
                <Label Text="{Binding Title}"
                       Style="{StaticResource CardTitleStyle}"
                       FontSize="12"
                       VerticalOptions="Center" />
                <Picker x:Name="SplinePicker" Grid.Column="1"
                        ItemsSource="{Binding PickerOptions}"
                        SelectedIndex="{Binding SelectedOptionIndex}"
                        FontSize="9"
                        TextColor="{Binding AccentColor}"
                        BackgroundColor="Transparent"
                        HorizontalOptions="End"
                        VerticalOptions="Center"
                        HeightRequest="20"
                        WidthRequest="65"
                        IsVisible="False" />
            </Grid>
            
            <!-- Trend value (below title) -->
            <Label Text="{Binding Trend}"
                   Grid.Row="1"
                   FontSize="20"
                   FontAttributes="Bold"
                   TextColor="{Binding AccentColor}"
                   Margin="0,6,0,0" />
            
            <!-- ===== CHART AREA (Row 2) ===== -->
            
            <!-- BAR CHART: dynamic bars from BarValues + SubText on right -->
            <Grid x:Name="BarChartArea" Grid.Row="2" ColumnDefinitions="*,Auto" IsVisible="False" Margin="0,8,0,0">
                <!-- Dynamic bars from repository -->
                <HorizontalStackLayout Spacing="4" VerticalOptions="End" HorizontalOptions="Start"
                                       BindableLayout.ItemsSource="{Binding BarValues}">
                    <BindableLayout.ItemTemplate>
                        <DataTemplate x:DataType="sys:Double">
                            <BoxView WidthRequest="8" HeightRequest="{Binding .}" CornerRadius="2" BackgroundColor="{Binding Source={x:Reference this}, Path=AccentColor}" Opacity="0.7" />
                        </DataTemplate>
                    </BindableLayout.ItemTemplate>
                </HorizontalStackLayout>
                <!-- SubText on right -->
                <Label Grid.Column="1" Text="{Binding SubText}" FontSize="10" TextColor="{Binding AccentColor}" VerticalOptions="End" />
            </Grid>
            
            <!-- LINE CHART: sharp polyline spanning full width -->
            <Path x:Name="LineChartArea" Grid.Row="2"
                  Data="{Binding PathData, Source={x:Reference this}}"
                  Stroke="{Binding AccentColor}"
                  StrokeThickness="2"
                  Aspect="Fill"
                  IsVisible="False"
                  Margin="0,8,0,0"
                  VerticalOptions="Fill"
                  HorizontalOptions="Fill"
                  Opacity="0.7" />
            
            <!-- SPLINE CHART: smooth curve with dots -->
            <Grid x:Name="SplineChartArea" Grid.Row="2" IsVisible="False" Margin="0,8,0,0">
                <Path Data="{Binding PathData, Source={x:Reference this}}"
                      Stroke="{Binding AccentColor}"
                      StrokeThickness="2"
                      Aspect="Fill"
                      VerticalOptions="Fill"
                      HorizontalOptions="Fill"
                      Opacity="0.7" />
                <!-- Circular nodes on spline (dynamic from BarValues) -->
                <HorizontalStackLayout Spacing="20" VerticalOptions="Center"
                                       BindableLayout.ItemsSource="{Binding BarValues}">
                    <BindableLayout.ItemTemplate>
                        <DataTemplate x:DataType="sys:Double">
                            <Ellipse WidthRequest="8" HeightRequest="8" Fill="{Binding Source={x:Reference this}, Path=AccentColor}" />
                        </DataTemplate>
                    </BindableLayout.ItemTemplate>
                </HorizontalStackLayout>
            </Grid>
            
            <!-- WAVE CHART (default): simple wave line -->
            <Path x:Name="WaveChartArea" Grid.Row="2"
                  Data="{Binding PathData, Source={x:Reference this}}"
                  Stroke="{Binding AccentColor}"
                  StrokeThickness="2"
                  Aspect="Fill"
                  Margin="0,8,0,0"
                  VerticalOptions="End"
                  HorizontalOptions="Fill"
                  Opacity="0.6" />
        </Grid>
        
        <!-- Triggers to show/hide chart areas based on ChartType -->
        <Border.Triggers>
            <DataTrigger TargetType="Border" Binding="{Binding ChartType, Source={x:Reference this}}" Value="bar">
                <Setter TargetName="BarChartArea" Property="IsVisible" Value="True" />
                <Setter TargetName="LineChartArea" Property="IsVisible" Value="False" />
                <Setter TargetName="SplineChartArea" Property="IsVisible" Value="False" />
                <Setter TargetName="WaveChartArea" Property="IsVisible" Value="False" />
            </DataTrigger>
            <DataTrigger TargetType="Border" Binding="{Binding ChartType, Source={x:Reference this}}" Value="line">
                <Setter TargetName="BarChartArea" Property="IsVisible" Value="False" />
                <Setter TargetName="LineChartArea" Property="IsVisible" Value="True" />
                <Setter TargetName="SplineChartArea" Property="IsVisible" Value="False" />
                <Setter TargetName="WaveChartArea" Property="IsVisible" Value="False" />
            </DataTrigger>
            <DataTrigger TargetType="Border" Binding="{Binding ChartType, Source={x:Reference this}}" Value="spline">
                <Setter TargetName="BarChartArea" Property="IsVisible" Value="False" />
                <Setter TargetName="LineChartArea" Property="IsVisible" Value="False" />
                <Setter TargetName="SplineChartArea" Property="IsVisible" Value="True" />
                <Setter TargetName="WaveChartArea" Property="IsVisible" Value="False" />
                <Setter TargetName="SplinePicker" Property="IsVisible" Value="True" />
            </DataTrigger>
            <DataTrigger TargetType="Border" Binding="{Binding ChartType, Source={x:Reference this}}" Value="wave">
                <Setter TargetName="BarChartArea" Property="IsVisible" Value="False" />
                <Setter TargetName="LineChartArea" Property="IsVisible" Value="False" />
                <Setter TargetName="SplineChartArea" Property="IsVisible" Value="False" />
                <Setter TargetName="WaveChartArea" Property="IsVisible" Value="True" />
            </DataTrigger>
        </Border.Triggers>
    </Border>
    
</ContentView>
