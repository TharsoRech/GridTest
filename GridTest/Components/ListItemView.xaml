<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="GridTest.Components.ListItemView">
    
    <Grid ColumnDefinitions="40,*" RowDefinitions="Auto" Padding="0,8">
        <!-- Timeline Column -->
        <Grid Grid.Column="0" RowDefinitions="Auto" VerticalOptions="Start">
            <!-- Vertical Line -->
            <BoxView WidthRequest="2"
                     HeightRequest="60"
                     Color="#E0E0E0"
                     HorizontalOptions="Center"
                     VerticalOptions="Center" />
            
            <!-- Colored Circle with Icon -->
            <Border WidthRequest="32"
                    HeightRequest="32"
                    BackgroundColor="{Binding ColorHex}"
                    StrokeThickness="0"
                    HorizontalOptions="Center"
                    VerticalOptions="Start">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="16" />
                </Border.StrokeShape>
                <Label Text="{Binding Icon}"
                       FontSize="14"
                       TextColor="White"
                       HorizontalOptions="Center"
                       VerticalOptions="Center" />
            </Border>
        </Grid>
        
        <!-- Content Column -->
        <Grid Grid.Column="1" 
              RowDefinitions="Auto,Auto" 
              ColumnDefinitions="*,Auto"
              Padding="12,0,0,0">
            <!-- Title -->
            <Label Text="{Binding Title}"
                   FontSize="14"
                   FontAttributes="Bold"
                   TextColor="{StaticResource TextPrimary}" />
            
            <!-- Time Ago -->
            <Label Text="{Binding TimeAgo}"
                   Grid.Column="1"
                   FontSize="12"
                   TextColor="{StaticResource TextSecondary}"
                   VerticalOptions="Center" />
            
            <!-- Description -->
            <Label Text="{Binding Description}"
                   Grid.Row="1"
                   FontSize="12"
                   TextColor="{StaticResource TextSecondary}"
                   Margin="0,4,0,0" />
        </Grid>
    </Grid>
    
</ContentView>
