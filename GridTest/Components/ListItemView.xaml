<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="GridTest.Components.ListItemView">
    
    <Grid ColumnDefinitions="40,*" Padding="0,6">
        <!-- Timeline Column -->
        <Grid Grid.Column="0" VerticalOptions="Fill">
            <!-- Vertical connecting line -->
            <BoxView WidthRequest="2"
                     Color="#E0E0E0"
                     HorizontalOptions="Center"
                     VerticalOptions="Fill" />
            
            <!-- Colored Node Circle -->
            <Border WidthRequest="28"
                    HeightRequest="28"
                    BackgroundColor="{Binding ColorHex}"
                    StrokeThickness="0"
                    HorizontalOptions="Center"
                    VerticalOptions="Start">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="14" />
                </Border.StrokeShape>
                <Label Text="{Binding Icon}"
                       FontSize="12"
                       TextColor="White"
                       HorizontalOptions="Center"
                       VerticalOptions="Center" />
            </Border>
        </Grid>
        
        <!-- Content Column -->
        <Grid Grid.Column="1" 
              RowDefinitions="Auto,Auto" 
              ColumnDefinitions="*,Auto"
              Padding="8,0,0,0">
            <!-- Title -->
            <Label Text="{Binding Title}"
                   FontSize="14"
                   FontAttributes="Bold"
                   TextColor="{StaticResource TextPrimary}"
                   LineBreakMode="TailTruncation" />
            
            <!-- Time Ago -->
            <Label Text="{Binding TimeAgo}"
                   Grid.Column="1"
                   FontSize="11"
                   TextColor="{StaticResource TextSecondary}"
                   VerticalOptions="Center" />
            
            <!-- Description -->
            <Label Text="{Binding Description}"
                   Grid.Row="1"
                   Grid.ColumnSpan="2"
                   FontSize="12"
                   TextColor="{StaticResource TextSecondary}"
                   Margin="0,2,0,0"
                   LineBreakMode="TailTruncation" />
        </Grid>
    </Grid>
    
</ContentView>
